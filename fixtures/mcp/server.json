{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-07-09/server.json",
  "name": "io.github.example/weather",
  "description": "Weather data MCP server",
  "version": "1.2.0",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.example.com/mcp",
      "headers": [
        { "name": "X-API-Key", "is_required": true, "is_secret": true }
      ]
    }
  ],
  "packages": [
    {
      "registry_type": "npm",
      "identifier": "@example/weather-mcp",
      "version": "1.2.0",
      "runtime_hint": "npx",
      "environment_variables": [
        { "name": "WEATHER_API_KEY", "is_required": true, "is_secret": true }
      ]
    }
  ],
  "tools": [
    {
      "name": "get_forecast",
      "description": "Get the weather forecast for a city",
      "inputSchema": {
        "type": "object",
        "required": ["city"],
        "properties": {
          "city": { "type": "string" },
          "days": { "type": "integer", "default": 3 }
        }
      }
    },
    {
      "name": "list_stations",
      "inputSchema": {
        "type": "object",
        "properties": {}
      }
    }
  ]
}
