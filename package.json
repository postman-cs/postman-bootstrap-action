{
  "name": "@postman-cse/onboarding-bootstrap",
  "version": "2.7.0",
  "description": "Bootstrap Postman workspaces, specs, and collections from OpenAPI.",
  "type": "module",
  "main": "dist/index.cjs",
  "bin": {
    "postman-bootstrap": "dist/cli.cjs"
  },
  "files": [
    "action.yml",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "build": "npm run typecheck && rm -rf dist && esbuild src/index.ts --bundle --platform=node --target=node24 --format=cjs --alias:jsonc-parser=jsonc-parser/lib/esm/main.js --outfile=dist/index.cjs && esbuild src/main.ts --bundle --platform=node --target=node24 --format=cjs --alias:jsonc-parser=jsonc-parser/lib/esm/main.js --outfile=dist/action.cjs && esbuild src/cli.ts --bundle --platform=node --target=node24 --format=cjs --alias:jsonc-parser=jsonc-parser/lib/esm/main.js --outfile=dist/cli.cjs",
    "verify:dist": "npm run build && git diff --ignore-space-at-eol --text --exit-code -- dist",
    "docs:tables": "node scripts/render-action-tables.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "github-action",
    "postman"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/io": "^3.0.2",
    "@apidevtools/json-schema-ref-parser": "15.4.0",
    "@exodus/schemasafe": "1.3.0",
    "@postman-cse/automation-telemetry-core": "^0.2.0",
    "@postman/asyncapi-parser": "^3.5.0",
    "@postman/protobufjs": "^7.5.4-postman.2",
    "@postman/runtime.models": "^1.11.1",
    "@readme/openapi-parser": "^6.1.2",
    "fast-xml-parser": "^5.7.0",
    "graphql": "^16.9.0",
    "undici": "^6.27.0"
  },
  "overrides": {
    "undici": "^6.27.0",
    "picomatch": ">=4.0.4",
    "lodash": "^4.18.1",
    "uuid": "^11.1.1",
    "flatted": "^3.4.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "esbuild": "0.28.1",
    "eslint": "^10.4.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7",
    "yaml": "^2.9.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/postman-cs/postman-bootstrap-action"
  }
}
