                  "var grpcSpec = JSON.parse("{\\"id\\":\\"telecom.network.v1.TowerService/GetNetworkEvent\\",\\"methodPath\\":\\"telecom.network.v1.TowerService/GetNetworkEvent\\",\\"stream\\":\\"unary\\",\\"responseType\\":\\"telecom.network.v1.NetworkEvent\\",\\"responseShape\\":{\\"fields\\":[{\\"name\\":\\"event_id\\",\\"jsonName\\":\\"eventId\\",\\"jsonType\\":\\"string\\",\\"repeated\\":false,\\"map\\":false,\\"required\\":false},{\\"name\\":\\"occurred_at\\",\\"jsonName\\":\\"occurredAt\\",\\"jsonType\\":\\"string\\",\\"jsonFormat\\":\\"proto-timestamp\\",\\"repeated\\":false,\\"map\\":false,\\"required\\":false},{\\"name\\":\\"ttl\\",\\"jsonName\\":\\"ttl\\",\\"jsonType\\":\\"string\\",\\"jsonFormat\\":\\"proto-duration\\",\\"repeated\\":false,\\"map\\":false,\\"required\\":false},{\\"name\\":\\"note\\",\\"jsonName\\":\\"note\\",\\"jsonType\\":\\"string\\",\\"repeated\\":false,\\"map\\":false,\\"required\\":false,\\"nullable\\":true},{\\"name\\":\\"tower\\",\\"jsonName\\":\\"tower\\",\\"jsonType\\":\\"object\\",\\"repeated\\":false,\\"map\\":false,\\"required\\":false,\\"shape\\":{\\"fields\\":[{\\"name\\":\\"tower_id\\",\\"jsonName\\":\\"towerId\\",\\"jsonType\\":\\"string\\",\\"repeated\\":false,\\"map\\":false,\\"required\\":false},{\\"name\\":\\"location\\",\\"jsonName\\":\\"location\\",\\"jsonType\\":\\"object\\",\\"repeated\\":false,\\"map\\":false,\\"required\\":false,\\"shape\\":{\\"fields\\":[{\\"name\\":\\"latitude\\",\\"jsonName\\":\\"latitude\\",\\"jsonType\\":\\"double\\",\\"repeated\\":false,\\"map\\":false,\\"required\\":false},{\\"name\\":\\"longitude\\",\\"jsonName\\":\\"longitude\\",\\"jsonType\\":\\"double\\",\\"repeated\\":false,\\"map\\":false,\\"required\\":false}],\\"oneofs\\":[]}},{\\"name\\":\\"quality\\",\\"jsonName\\":\\"quality\\",\\"jsonType\\":\\"enum\\",\\"repeated\\":false,\\"map\\":false,\\"required\\":false,\\"enumValues\\":[\\"SIGNAL_QUALITY_EXCELLENT\\",\\"SIGNAL_QUALITY_FAIR\\",\\"SIGNAL_QUALITY_GOOD\\",\\"SIGNAL_QUALITY_POOR\\",\\"SIGNAL_QUALITY_UNSPECIFIED\\"]},{\\"name\\":\\"supported_bands\\",\\"jsonName\\":\\"supportedBands\\",\\"jsonType\\":\\"string\\",\\"repeated\\":true,\\"map\\":false,\\"required\\":false},{\\"name\\":\\"subscriber_count\\",\\"jsonName\\":\\"subscriberCount\\",\\"jsonType\\":\\"string\\",\\"intType\\":\\"int64\\",\\"repeated\\":false,\\"map\\":false,\\"required\\":false},{\\"name\\":\\"operator_label\\",\\"jsonName\\":\\"operatorLabel\\",\\"jsonType\\":\\"string\\",\\"repeated\\":false,\\"map\\":false,\\"required\\":false},{\\"name\\":\\"attributes\\",\\"jsonName\\":\\"attributes\\",\\"jsonType\\":\\"object\\",\\"repeated\\":false,\\"map\\":true,\\"required\\":false,\\"mapValueType\\":\\"string\\"}],\\"oneofs\\":[]}},{\\"name\\":\\"pong\\",\\"jsonName\\":\\"pong\\",\\"jsonType\\":\\"object\\",\\"repeated\\":false,\\"map\\":false,\\"required\\":false,\\"shape\\":{\\"fields\\":[{\\"name\\":\\"tower_id\\",\\"jsonName\\":\\"towerId\\",\\"jsonType\\":\\"string\\",\\"repeated\\":false,\\"map\\":false,\\"required\\":false},{\\"name\\":\\"reachable\\",\\"jsonName\\":\\"reachable\\",\\"jsonType\\":\\"boolean\\",\\"repeated\\":false,\\"map\\":false,\\"required\\":false}],\\"oneofs\\":[]}},{\\"name\\":\\"waypoints\\",\\"jsonName\\":\\"waypoints\\",\\"jsonType\\":\\"object\\",\\"repeated\\":false,\\"map\\":true,\\"required\\":false,\\"mapValueType\\":\\"object\\",\\"mapValueShape\\":{\\"fields\\":[{\\"name\\":\\"latitude\\",\\"jsonName\\":\\"latitude\\",\\"jsonType\\":\\"double\\",\\"repeated\\":false,\\"map\\":false,\\"required\\":false},{\\"name\\":\\"longitude\\",\\"jsonName\\":\\"longitude\\",\\"jsonType\\":\\"double\\",\\"repeated\\":false,\\"map\\":false,\\"required\\":false}],\\"oneofs\\":[]}},{\\"name\\":\\"mask\\",\\"jsonName\\":\\"mask\\",\\"jsonType\\":\\"string\\",\\"jsonFormat\\":\\"proto-field-mask\\",\\"repeated\\":false,\\"map\\":false,\\"required\\":false},{\\"name\\":\\"payload\\",\\"jsonName\\":\\"payload\\",\\"jsonType\\":\\"string\\",\\"jsonForma