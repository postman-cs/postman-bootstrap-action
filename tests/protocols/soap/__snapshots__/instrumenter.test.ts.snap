  ],
  "warnings": [
    "SOAP_LINT_DOC_LITERAL_WRAPPED: operation GetStockPrice follows the doc-literal-wrapped convention (input wrapper element <GetStockPrice> is named after the operation); advisory only -- convention-based detection, not a WS-I requirement",
    "SOAP_LINT_DOC_LITERAL_WRAPPED: operation ListSymbols follows the doc-literal-wrapped convention (input wrapper element <ListSymbols> is named after the operation); advisory only -- convention-based detection, not a WS-I requirement",
